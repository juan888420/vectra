# PostgreSQL connection string used by Prisma (see prisma.config.ts).
DATABASE_URL="postgresql://user:password@localhost:5432/vectra_dev?schema=public"

# Signs JWT access tokens. Minimum 32 characters; generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="change-me-to-a-random-string-of-at-least-32-chars"

# Optional — defaults shown (see src/config/env.ts).
# NODE_ENV="development"
# HOST="127.0.0.1"
# PORT="3001"
# CORS_ORIGIN="http://localhost:5173"
